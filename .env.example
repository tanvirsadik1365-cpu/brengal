RESEND_API_KEY=
ORDER_EMAIL_FROM=Bengal Restaurant <orders@bengal.restaurant>
ORDER_EMAIL_REPLY_TO=bengal.restaurant78@gmail.com
BOOKING_EMAIL_TO=bengal.restaurant78@gmail.com
BOOKING_EMAIL_FROM=Bengal Restaurant <bookings@bengal.restaurant>

STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
